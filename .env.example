APP_NAME="CV Analyzer"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Connexions staff (non publiques — ne pas lier depuis /login)
ADMIN_LOGIN_PATH=acces-admin-plateforme
GERANT_LOGIN_PATH=acces-gerant-entreprise
ADMIN_APP_PREFIX=espace-admin
GERANT_APP_PREFIX=espace-gerant

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cvapp
DB_USERNAME=postgres
DB_PASSWORD=
# Railway Postgres: add plugin, then set DB_URL (or Laravel reads DATABASE_URL)
# DB_URL=

# --- Production (Railway) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-app.up.railway.app
# SESSION_SECURE_COOKIE=true
# CACHE_STORE=database
# LOG_LEVEL=warning

# SQLite (alternative)
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# log = e-mails écrits dans storage/logs/laravel.log (pas de Gmail réel)
# Pour de vrais e-mails : MAIL_MAILER=smtp + identifiants SMTP
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
