@startuml cas-utilisation
left to right direction

actor Candidat
actor RH as "RH (sous_admin)"
actor Gerant as "Gérant (super_admin)"
actor Admin as "Admin plateforme"

rectangle "CvAnalyzer" {
  usecase "Consulter offres" as UC1
  usecase "Déposer / modifier CV (24h)" as UC2
  usecase "Suivre candidature" as UC3
  usecase "Analyser et filtrer CV" as UC4
  usecase "Importer CV" as UC5
  usecase "Gérer postes" as UC6
  usecase "Gérer équipe RH\n(tri volume postes)" as UC7
  usecase "Modifier RH" as UC8
  usecase "Désactiver / réactiver\n(cascade snapshot)" as UC14
  usecase "Description entreprise" as UC9
  usecase "Back-office gérant" as UC10
  usecase "Créer / modifier gérants" as UC11
  usecase "Back-office admin" as UC12
  usecase "Messages contact" as UC13
}

Candidat --> UC1
Candidat --> UC2
Candidat --> UC3

RH --> UC4
RH --> UC5
RH --> UC6

Gerant --> UC7
Gerant --> UC8
Gerant --> UC9
Gerant --> UC10
Gerant --> UC14

Admin --> UC11
Admin --> UC12
Admin --> UC13
Admin --> UC14

note right of UC14
  Snapshot JSON etat_cascade_snapshot
  Numéro de dossier = cvs.id
end note

@enduml
